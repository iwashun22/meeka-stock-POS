extends layout 

block content
  h1(class="page-title kn-bold") สแกนรหัสสินค้า
  form(action="/product/search", method="GET" class="search-form")
    div(class="search-bar")
      input(class="search-input" type="text" id="sku-id" name="sku_id" autocomplete="off" value=lastSearch || '')
      button(type="button" id="scan-icon-btn")
    div
      button(type="submit" class="search-btn pp-bold") ค้นหา

  if notFound
    p(class="not-found-text") ไม่พบสินค้า

  if data
    table(class="product-table pp-reg")
      tr(class="name-row")
        th อะไหล่
        td(id="product-name")
          span #{data.name}
      tr(class="model-row")
        th ชื่อรุ่น
        td
          span #{data.model}
      if user && user.role
        tr
          th ที่เก็บ
          td
            for location in data.location.split("\n")
              div #{location}
      tr
        th จำนวน
        td(id="product-stock") #{data.stock}

      if user && user.role
        tr
          th ราคา
          td(id="product-price")
            span #{data.selling_price} ฿

    div(class="update-link-container")
      a(href=`/update/${data.sku_id}`)
        button(class="update-link kn-reg") แก้ไขข้อมูล

  if user && user.role === 'admin'
    a(href='/update/new/product')
      button(id="add-product-btn")
