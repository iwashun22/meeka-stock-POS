extends layout 

block content
  form(action="/product", method="POST" class="search-form")
    div
      label(for="sku-id") Search Products:
      input(type="text" id="sku-id" name="sku_id" autocomplete="off" required value=data ? data.sku_id : '')
      div(id="scan-icon-container")
    div
      button(type="submit") Search

  if notFound
    p Product not found.

  if data
    div
      h2 #{data.name}
      p price:  #{data.price} THB
      p stock: #{data.count}

    div
      a(href=`/update/${data.sku_id}`)
        button Update Product
      //- form(action="/update", method="POST")
        input(type="hidden" name="id" value=data.id)
        div
          label(for="price") Update Price:
          input(type="number" name="price" step="0.01" required)
        div
          label(for="count") Update Stock Count:
          input(type="number" name="count" required)
        div
          button(type="submit") Update