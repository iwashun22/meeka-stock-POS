extends layout

block content
  h1(class="page-title kn-bold") อัปเดตสินค้า

  table(class="product-table pp-reg")
    tr
      th รหัส
      td(class="product-id") 
        div(class="table-data-wrapper")
          span #{data.sku_id}
    tr(class="name-row")
      th สินค้า
      td(id="product-name")
        if user.roles.name === "admin"
          form(id="edit-product-name" class="editable" action=`/update/change/${data.sku_id}` method="POST")
            input(type="hidden" name="on" value="product_name")
            input(type="text" name="new_value")
            div(class="editable-btn-container")
              button(class="cancel-editable kn-reg" type="button") ยกเลิก
              button(class="submit-editable kn-reg" type="submit") บันทึก
        div(class="table-data-wrapper")
          span #{data.name}
          if user.roles.name === "admin"
            div(class="editable-btn-container")
              button(class="admin-edit-btn kn-reg" data-html-for="edit-product-name" data-input-value=data.name) แก้ไข
    tr
      th จำนวน
      td(id="product-stock")
        div(class="table-data-wrapper")
          span #{data.stock}

    if user.roles.name
      tr
        th ราคา
        td(id="product-price")
          if user.roles.name === "admin"
            form(id="edit-selling-price" class="editable" action=`/update/change/${data.sku_id}` method="POST")
              input(type="hidden" name="on" value="selling_price")
              input(id="edit-price-input" type="text" name="new_value")
              div(class="editable-btn-container")
                button(class="cancel-editable kn-reg" type="button") ยกเลิก
                button(class="submit-editable kn-reg" type="submit") บันทึก
          div(class="table-data-wrapper")
            span #{Number(data.selling_price).toFixed(2)} ฿
            if user.roles.name === "admin"
              div(class="editable-btn-container")
                button(class="admin-edit-btn kn-reg" data-html-for="edit-selling-price" data-input-value=`${Number(data.selling_price).toFixed(2)}`) แก้ไข

  p(class="updated-at kn-light") อัปเดตเมื่อ: #{data.updated_at}

  if !user.roles.name
    p(class="not-permitted kn-light") คุณไม่มีสิทธิ์ในการอัปเดตข้อมูลสินค้า หากเป็นพนักงานกรุณาแจ้งเพื่อขอสิทธิ์
  else
    section(class="action-container")
      div

        if ['employee', 'manager', 'admin'].includes(user.roles.name) && data.stock > 0
          button(id="sell-stock-btn" class="kn-bold") ขายสินค้า

        if ['manager', 'admin'].includes(user.roles.name)
          button(id="add-stock-btn" class="kn-bold") เพิ่มสินค้า

      form(id="update-stock-form" action=`/update/stock/${data.sku_id}` method="POST")
        input(id="action-name" type="hidden" name="action" value="sell")

        table(id="result-table")
          tr
            th(class="kn-reg") จาก
            td(colspan=2) #{data.stock}
          tr
            th(class="kn-reg" id="table-header-action-name") ขาย
            td
              button(id="decrement" type="button")
            td
              input(id="update-quantity" type="text" name="quantity" value="1" inputmode="numeric")
            td
              button(id="increment" type="button")
            td(id="sell-total-price" data-selling-price=`${data.selling_price}`)
          tr
            th(class="kn-bold") คงเหลือ
            td(id="table-data-final-quantity" colspan=2) 11
        tr
        div(class="final-btn-container")
          button(class="kn-reg" type="button" id="close-form-btn") ยกเลิก
          button(class="kn-reg" type="submit" id="save-form-btn") บันทึก


    //- if user.roles.name === 'employee'
    //-   p you are an employee
    //- else if user.roles.name === 'manager'
    //-   p you are a manager
    //- else if user.roles.name === 'admin'
    //-   p you are an admin